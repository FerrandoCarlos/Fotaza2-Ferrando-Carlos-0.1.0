mixin card(pub)
  a(href="/publicacion/${pub.id}" class="block")
    article(class="bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800 hover:border-amber-400 transition-colors")
      if pub.Imagens && pub.Imagens.length
        figure(class="relative")
          if pub.Imagens[0].Licencium && pub.Imagens[0].Licencium.tiene_copyright
            img(class="w-full h-48 object-cover blur-sm" src=pub.Imagens[0].datos alt=pub.titulo)
            div(class="absolute inset-0 flex items-center justify-center")
              span(class="text-amber-400 text-4xl") 🔒
          else
            img(class="w-full h-48 object-cover" src=pub.Imagens[0].datos alt=pub.titulo)
      else
        div(class="w-full h-48 bg-zinc-800 flex items-center justify-center")
          span(class="text-gray-600") Sin imagen
      div(class="p-4")
        h3(class="text-gray-100 font-semibold mb-1") #{pub.titulo}
        p(class="text-gray-500 text-sm") #{pub.Usuario ? pub.Usuario.nombre + ' ' + pub.Usuario.apellido : ''}

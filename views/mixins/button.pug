mixin btnPrimario(texto, type='submit')
  button(
    type=type
    class= "bg-amber-400 text-zinc-950 font-semibold py-3 rounded-lg hover:bg-amber-300 transition-colors w-full"
  ) #{texto}

mixin btnSecundario(texto, href)
  a(
    href=href
    class= "border border-zinc-700 text-gray-300 px-6 py-3 rounded-lg hover:border-amber-400 hover:text-amber-400 transition-colors"
  ) #{texto}

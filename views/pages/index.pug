extends ../layout.pug

block content
  include ../mixins/card.pug

  section(class="flex flex-col items-center justify-center py-24 text-center px-4")
    div(class="flex flex-col items-center mb-6")
      h1#hero-title(class="text-4xl font-bold text-amber-400") Bienvenido a
      img(class="h-40 w-auto" src="/img/logoMain.png" alt="Logo Fotaza 2")
    p(class="text-gray-400 text-xl mb-10 max-w-xl") Compartí y descubrí fotografías increíbles de la comunidad
    div(class="flex gap-4")
      a(class="bg-amber-400 text-zinc-950 font-semibold px-6 py-3 rounded-lg hover:bg-amber-300 transition-colors" href="/register") Comenzar
      a(class="border border-zinc-700 text-gray-300 px-6 py-3 rounded-lg hover:border-amber-400 hover:text-amber-400 transition-colors" href="/login") Ingresar

  section(class="max-w-7xl mx-auto px-8 py-12")
    h2(class="text-2xl font-bold text-gray-100 mb-8") Fotos recientes
    if publicaciones && publicaciones.length
      div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6")
        each pub in publicaciones
          +card(pub)
    else
      p(class="text-gray-500 text-center py-12") No hay publicaciones todavía

  section(class="max-w-7xl mx-auto px-8 py-8 border-t border-zinc-800")
    h2(class="text-xl font-bold text-gray-100 mb-4") Explorar por etiquetas
    if etiquetas && etiquetas.length
      div(class="flex flex-wrap gap-3")
        each etiqueta in etiquetas
          a(class="bg-zinc-800 text-gray-300 px-4 py-2 rounded-full text-sm hover:bg-amber-400 hover:text-zinc-950 transition-colors" href= `/buscar?etiqueta=${etiqueta.nombre}`) # #{etiqueta.nombre}
    else
      p(class="text-gray-500") No hay etiquetas todavía

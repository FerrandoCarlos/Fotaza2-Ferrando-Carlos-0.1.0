header(class="bg-zinc-900 border-b border-zinc-800" role="banner")
  nav(class="max-w-7xl mx-auto h-16 px-8 flex items-center justify-between" role="navigation" aria-label="Navegación principal")
    a(class="flex items-center" href="/" aria-label="Ir al inicio de Fotaza 2")
      img(class="h-10 w-auto" src="/img/logoNav.png" alt="Fotaza 2")
    div(class="hidden sm:flex items-center gap-8" role="menubar")
      a(class="text-gray-400 hover:text-amber-400 transition-colors text-sm font-medium" href="/" role="menuitem") Inicio
      a(class="text-gray-400 hover:text-amber-400 transition-colors text-sm font-medium" href="/login" role="menuitem") Ingresar
      a(class="bg-amber-400 text-zinc-950 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-amber-300 transition-colors" href="/register" role="menuitem") Registrarse
    div(class="sm:hidden")
      button#navbar-toggle(
        class="size-9 flex justify-center items-center rounded-lg bg-zinc-800 border border-zinc-700 text-gray-400 hover:bg-zinc-700 hover:text-amber-400 transition-colors focus:outline-none"
        type="button"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="navbar-menu"
      )
        svg#icon-open(class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
		stroke="currentColor" stroke-width="2" aria-hidden="true")
          line(x1="3" y1="6" x2="21" y2="6")
          line(x1="3" y1="12" x2="21" y2="12")
          line(x1="3" y1="18" x2="21" y2="18")
        svg#icon-close(class="hidden size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
		stroke="currentColor" stroke-width="2" aria-hidden="true")
          path(d="M18 6 6 18")
          path(d="m6 6 12 12")
  div#navbar-menu(class="hidden sm:hidden border-t border-zinc-800" role="region" aria-labelledby="navbar-toggle")
    nav(class="flex flex-col px-8 py-4 gap-4" role="menu")
      a(class="text-gray-400 hover:text-amber-400 transition-colors text-sm font-medium" href="/" role="menuitem") Inicio
      a(class="text-gray-400 hover:text-amber-400 transition-colors text-sm font-medium" href="/login" role="menuitem") Ingresar
      a(class="text-amber-400 font-semibold text-sm" href="/register" role="menuitem") Registrarse
